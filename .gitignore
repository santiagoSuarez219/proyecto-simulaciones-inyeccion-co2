.venv/
/.claude
skills-lock.json
__pycache__/
*.pyc
*.egg-info/
.pytest_cache/
.ipynb_checkpoints/

outputs/checkpoints/*
!outputs/checkpoints/.gitkeep
outputs/logs/*
!outputs/logs/.gitkeep
outputs/figures/*
!outputs/figures/.gitkeep
# Artefactos que scripts/train.py escribe en la raíz de outputs/ (config, historial de
# métricas, curvas, calibración de incertidumbre): generados en runtime, no versionados.
outputs/*.json
outputs/*.png

# spec-001: outputs/<experiment_name>/ (seed_<seed>/, run_manifest.json, config, etc.)
# — mismo criterio que el resto de outputs/: generado en runtime, no versionado. Los tres
# subdirectorios de siempre se re-incluyen para que las reglas de arriba (que solo ignoran
# su contenido, no el directorio) sigan aplicando igual que antes.
outputs/*/
!outputs/checkpoints/
!outputs/logs/
!outputs/figures/

# ETL (fno_co2.etl, ex-cmg2tensor): datos y artefactos generados, no versionados
# /data es un symlink a disco externo (ver specs/backlog.md, notas de hardware) — nunca
# debe rastrearse, ni siquiera por accidente con un `git add` amplio.
/data
data/raw/*
data/processed/*
*.pt
*.npy
*.npz

raw_structure_report.txt
standardization_log.txt
result.txt
data_listing.txt

reports/
reports/global_normalization/
reports/batch_simulations_report.json
reports/*_report.json
reports/subset_split.csv

*.log
sql/simulaciones.db
