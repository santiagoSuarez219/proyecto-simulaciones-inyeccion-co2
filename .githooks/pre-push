#!/usr/bin/env bash
# ==========================================================================
# pre-push — Red de seguridad: BLOQUEA cualquier push a main que contenga
# docs/, specs/ o CLAUDE.md. Complementa a scripts/promote-to-main.sh
# (el metodo correcto para actualizar main). Este hook atrapa el olvido de
# usar el script (p. ej. un `git push origin development:main` accidental).
#
# Instalacion (una vez por clon):
#   scripts/install-git-hooks.sh
# (copia este archivo a .git/hooks/pre-push, la ubicacion que git respeta
#  siempre; un core.hooksPath relativo NO se honra de forma fiable en push.)
# Para desactivar temporalmente:
#   rm .git/hooks/pre-push
# ==========================================================================
set -euo pipefail

PROTECTED_RE='^(docs/|specs/|CLAUDE\.md)'
ZERO="0000000000000000000000000000000000000000"

while read -r local_ref local_sha remote_ref remote_sha; do
  [ "$remote_ref" = "refs/heads/main" ] || continue   # solo vigilamos main
  [ "$local_sha" = "$ZERO" ] && continue               # borrado de rama: ignorar

  if git ls-tree -r "$local_sha" --name-only | grep -qE "$PROTECTED_RE"; then
    echo "pre-push: BLOQUEADO — el commit $local_sha destinado a main contiene" >&2
    echo "          docs/, specs/ o CLAUDE.md, que no deben vivir en main." >&2
    echo "          Usa 'scripts/promote-to-main.sh' para promover sin esas rutas." >&2
    exit 1
  fi
done

exit 0
